{
  "name": "japanese-verb-master-backend",
  "version": "1.0.0",
  "description": "Backend API for Japanese verb conjugation",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node --env-file-if-exists=.env server.js",
    "dev": "node --env-file-if-exists=.env --watch server.js",
    "build": "npm install && npm run db:import && npm run kb:build",
    "db:import": "node import-words.js",
    "db:fetch": "node fetch-words.js",
    "kb:build": "node scripts/kb-build.js && (cd ../frontend && npm install && npm run build) && rm -rf public && cp -R ../frontend/dist public",
    "kb:eval": "node scripts/kb-eval.js",
    "kb:eval:answer": "node scripts/kb-eval-answer.js",
    "kb:tune": "node scripts/kb-tune.js",
    "mcp:jvm": "node scripts/jvm-mcp-server.js",
    "test": "node --test 'tests/*.test.js'"
  },
  "dependencies": {
    "@langchain/langgraph": "^1.3.2",
    "@larksuiteoapi/node-sdk": "^1.67.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "alipay-sdk": "^4.14.0",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "js-tiktoken": "^1.0.21",
    "kuromoji": "^0.1.2",
    "langsmith": "^0.7.3",
    "ollama": "^0.6.3",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "sqlite-vec": "^0.1.9",
    "wanakana": "^5.3.1"
  }
}

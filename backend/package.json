{
  "name": "japanese-verb-master-backend",
  "version": "1.0.0",
  "description": "Backend API for Japanese verb conjugation",
  "type": "module",
  "main": "server.ts",
  "scripts": {
    "start": "tsx --env-file-if-exists=.env server.ts",
    "dev": "tsx --env-file-if-exists=.env watch server.ts",
    "build": "npm install && npm run db:import && npm run kb:build",
    "db:import": "tsx import-words.ts",
    "db:fetch": "tsx fetch-words.ts",
    "kb:build": "tsx scripts/kb-build.ts && (cd ../frontend && npm install && npm run build) && rm -rf public && cp -R ../frontend/dist public",
    "kb:eval": "tsx scripts/kb-eval.ts",
    "kb:eval:answer": "tsx scripts/kb-eval-answer.ts",
    "kb:tune": "tsx scripts/kb-tune.ts",
    "mcp:jvm": "tsx scripts/jvm-mcp-server.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@langchain/langgraph": "^1.3.2",
    "@larksuiteoapi/node-sdk": "^1.67.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "alipay-sdk": "^4.14.0",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "js-tiktoken": "^1.0.21",
    "kuromoji": "^0.1.2",
    "langsmith": "^0.7.3",
    "ollama": "^0.6.3",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "sqlite-vec": "^0.1.9",
    "tsx": "^4.22.4",
    "wanakana": "^5.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "typescript": "^6.0.3"
  }
}
